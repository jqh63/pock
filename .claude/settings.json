{
  "permissions": {
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*.key)",
      "Read(**/*.pem)",
      "Read(**/*.crt)",
      "Read(**/*.pfx)",
      "Read(**/id_rsa)",
      "Read(**/id_rsa.*)",
      "Read(**/id_ed25519)",
      "Read(**/id_ed25519.*)",
      "Read(**/credentials*)",
      "Read(**/auth.json)",
      "Read(**/secrets.*)",
      "Read(secrets/**)",
      "Read(**/secrets/**)",
      "Read(.git/config)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/pre-commit-secret-scan.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
