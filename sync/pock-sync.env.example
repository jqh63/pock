# /etc/pock-sync.env — chmod 0600, root:root
# Shared Bearer token, required on every sync operation (GET included).
# Generate with: openssl rand -hex 32
# Never committed anywhere — entered once per device in the PWA hub.
POCK_SYNC_TOKEN=<PLACEHOLDER>

# Optional scoped tokens (sharing a subset of apps with another person).
# Space-separated <token>:<app1,app2> entries; a scoped token reads/writes
# ONLY its listed apps (shared blobs), 403 elsewhere. Generate each token
# with: openssl rand -hex 32
#POCK_SYNC_SCOPED_TOKENS=<TOKEN_FAMILLE>:km

# Optional overrides (defaults shown)
#POCK_SYNC_DATA_DIR=/var/lib/pock-sync
#POCK_SYNC_MAX_BLOB_BYTES=262144
